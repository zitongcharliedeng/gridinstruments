{
  "name": "gridinstruments",
  "version": "1.0.0",
  "description": "Web-based isomorphic grid keyboard synthesizer — GridInstruments",
  "type": "module",
  "scripts": {
    "tangle": "bash scripts/tangle.sh",
    "prebuild": "npm run tangle",
    "build": "tsc && vite build",
    "pretest": "npm run tangle",
    "dev": "npm run tangle && vite",
    "preview": "vite preview",
    "lint": "eslint _generated/",
    "lint:ast": "ast-grep scan",
    "test": "playwright test",
    "test:update": "playwright test --update-snapshots",
    "verify": "npm run build && npm run lint && npx ast-grep scan && npx playwright test --project=firefox --workers=1"
  },
  "keywords": [
    "isomorphic",
    "keyboard",
    "synthesizer",
    "wicki-hayden",
    "dcompose",
    "music",
    "web-audio"
  ],
  "author": "",
  "license": "MIT",
  "devDependencies": {
    "@anthropic-ai/sdk": "^0.78.0",
    "@ast-grep/cli": "^0.41.0",
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.57.0",
    "@types/node": "^25.3.3",
    "eslint": "^10.0.1",
    "typescript": "^5.3.3",
    "typescript-eslint": "^8.56.0",
    "vite": "^5.0.10"
  },
  "dependencies": {
    "@tonejs/midi": "^2.0.28",
    "effect": "^3.19.19",
    "isomorphic-qwerty": "^0.0.4",
    "lucide": "^0.577.0",
    "overlayscrollbars": "^2.14.0",
    "roughjs": "^4.6.6",
    "slim-select": "^3.4.3",
    "tonal": "^6.0.1",
    "xstate": "^5.28.0"
  }
}
